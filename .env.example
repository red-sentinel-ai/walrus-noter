# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Postgres connection string used by Drizzle ORM.
# Local:  run `docker compose up` (see docker-compose.yml) then use the URL below.
# Cloud:  create a free DB on Neon (https://neon.tech) or Supabase and copy its
#         connection string.
DATABASE_URL=postgresql://noter:noter_secret@localhost:5434/noter

NEXT_PUBLIC_APP_URL=http://localhost:3002

NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com


# ── Enoki / Sui zkLogin ──────────────────────────────────────────────────────
# Enoki gives you sponsored (gasless) transactions + zkLogin wallets.
# Get an API key at https://portal.enoki.mystenlabs.com → create an app →
# copy the PUBLIC key. Register the Google client ID above as an auth provider
# inside the Enoki app so zkLogin can mint wallets for it.
NEXT_PUBLIC_ENOKI_API_KEY=enoki_public_...

NEXT_PUBLIC_SUI_NETWORK=testnet

NEXT_PUBLIC_ZK_PROVER_URL=https://prover-dev.mystenlabs.com/v1

# zkLogin salt service — derives the per-user salt for the Sui address.
SALT_SERVICE_URL=https://salt.api.mystenlabs.com/get_salt


# ── Walrus Memory (memwal) ───────────────────────────────────────────────────
# Walrus Memory stores encrypted AI memories on Walrus and serves semantic
# recall. A "relayer/server" does the embedding, SEAL encryption, Walrus
# upload/download and vector search. On-chain, a MemWalAccount holds your
# delegate keys.
#
# Get these from the Walrus Memory dashboard (https://memwal.ai / docs.memwal.ai),
# or self-host the relayer (see docs.memwal.ai → self-hosting).

# The on-chain Move package that defines account::create_account /
# account::add_delegate_key. Provided by the Walrus Memory deployment.
NEXT_PUBLIC_MEMWAL_PACKAGE_ID=0x...

# The shared Registry object ID that maps owner address → MemWalAccount.
NEXT_PUBLIC_MEMWAL_REGISTRY_ID=0x...

NEXT_PUBLIC_MEMWAL_SERVER_URL=http://localhost:9000

# Relayer URL the SERVER (Next.js API / tRPC) hits for remember/recall/analyze.
# Hosted default is https://relayer.memwal.ai
MEMWAL_SERVER_URL=http://localhost:8000

MEMWAL_PRIVATE_KEY=
MEMWAL_ACCOUNT_ID=
