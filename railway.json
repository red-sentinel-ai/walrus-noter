{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "apps/noter/Dockerfile",
        "watchPatterns": [
            "apps/noter/**",
            "packages/sdk/**"
        ]
    },
    "deploy": {
        "runtime": "V2",
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10,
        "healthcheckPath": "/"
    }
}
